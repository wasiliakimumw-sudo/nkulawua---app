# Django
SECRET_KEY=django-insecure-default-change-this
DEBUG=False
ALLOWED_HOSTS=nkula-wua.onrender.com
DJANGO_SETTINGS_MODULE=accounting_project.settings

# Database (PostgreSQL for Render; SQLite for local dev)
DATABASE_URL=sqlite:///db.sqlite3

# Security
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True

# Email (optional — for password resets, notifications)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_PORT=587

# Groq AI (free tier ~14,000 requests/day - get key at https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
